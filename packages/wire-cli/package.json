{
  "name": "@aigentive/wire-cli",
  "version": "1.0.2",
  "description": "Wire CLI — init, add, export.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
