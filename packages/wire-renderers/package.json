{
  "name": "@aigentive/wire-renderers",
  "version": "1.0.2",
  "description": "Wire — server/static renderers and framework-neutral adapter output.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/aigentive/wirediagram",
    "directory": "packages/wire-renderers"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@aigentive/wire-core": "^1.0.4"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
