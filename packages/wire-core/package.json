{
  "name": "@aigentive/wire-core",
  "version": "1.0.2",
  "description": "Wire — canonical schema, validation, normalization, and layout for LLM-first diagrams.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    },
    "./layout": {
      "types": "./dist/layout.d.ts",
      "default": "./dist/layout.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.23.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
