# Playground runtime
WIRE_SHARE_BACKEND=local
WIRE_SHARE_DIR=./storage/shares
WIRE_CLOUD_BACKEND=local
WIRE_CLOUD_DIR=./storage/cloud

# Hosted share storage, used when WIRE_SHARE_BACKEND is not local
BLOB_READ_WRITE_TOKEN=
BLOB_PUBLIC_BASE_URL=

# Authenticated wires workspace
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=

# Optional LLM chat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MAX_OUTPUT_TOKENS=4000
